{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(curl *|* sh:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(wget *|* sh:*)",
      "Read(.env)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  }
}
